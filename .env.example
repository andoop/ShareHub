SHAREHUB_ADMIN_PASS=change-me
SHAREHUB_ADMIN_USER=admin
SHAREHUB_ADDR=:8080
SHAREHUB_DATA_DIR=./data
# 大文件单独存放目录（可选）。留空则与数据库同放在 SHAREHUB_DATA_DIR 下。
# 推荐：把数据库(SHAREHUB_DATA_DIR)放在稳定的内置盘，仅把大文件(SHAREHUB_BLOB_DIR)
# 放到外接/扩展硬盘。这样外接盘休眠或掉线时只影响文件下载，控制台与数据库不受影响。
# SHAREHUB_BLOB_DIR=/Volumes/MyDrive/sharehub-blobs
SHAREHUB_JWT_SECRET=change-me-in-prod
# SHAREHUB_PUBLIC_BASE_URL=http://192.168.1.10:8080
# SHAREHUB_MAX_UPLOAD_MB=2048
